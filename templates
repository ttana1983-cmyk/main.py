<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>カジラク・コンシェルジュ</title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root { --bg: #faf8f5; --accent: #8c7851; --text: #4a4a4a; }
        body { font-family: sans-serif; background: var(--bg); color: var(--text); padding: 20px; margin: 0; line-height: 1.6; }
        .card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 20px; }
        h1, h2 { color: var(--accent); text-align: center; margin-top: 0; }
        .ingredient-item { display: flex; align-items: center; padding: 8px 0; border-bottom: 1px solid #eee; }
        .ingredient-item input { margin-right: 10px; transform: scale(1.2); }
        .btn-group { display: flex; gap: 10px; position: sticky; bottom: 20px; }
        button { flex: 1; padding: 15px 10px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; transition: 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .btn-primary { background: var(--accent); color: white; }
        .btn-secondary { background: #e0dace; color: var(--text); }
        button:active { transform: translateY(2px); box-shadow: none; }
        #loading { text-align: center; padding: 100px 20px; font-weight: bold; color: var(--accent); }
    </style>
</head>
<body>
    <div id="loading">Geminiが献立を考えています...<br>少々お待ちくださいね。</div>

    <div id="main-content" style="display:none;">
        <div id="recipe-area" class="card">
            <h2 id="r-name">料理名</h2>
            <div style="text-align:center; font-size:0.9em; margin-bottom:15px; color: #888;">
                ⏱ <span id="r-time"></span> | 💰 <span id="r-cost"></span>
            </div>
            
            <div id="cart-area">
                <h3 style="border-left: 4px solid var(--accent); padding-left: 10px;">🛒 買い物リスト</h3>
                <div id="ingredients"></div>
            </div>

            <h3 style="border-left: 4px solid var(--accent); padding-left: 10px; margin-top: 20px;">📖 作り方</h3>
            <div id="steps"></div>
            
            <p style="margin-top:20px; font-size:0.85em; color:#888; background: #f0ede9; padding: 10px; border-radius: 8px;">
                💡 <b>コツ:</b> <span id="r-tip"></span>
            </p>
        </div>

        <div class="btn-group">
            <button onclick="saveCart()" class="btn-secondary">🛒 買い物画像を保存</button>
            <button onclick="saveRecipe()" class="btn-primary">📖 レシピ画像を保存</button>
        </div>
        <p style="text-align:center; font-size:0.7em; color:#aaa; margin-top:15px;">© カジラク知恵袋</p>
    </div>

    <script>
        async function init() {
            await liff.init({ liffId: "2010225388-rXh2LiOR" });
            const urlParams = new URLSearchParams(window.location.search);
            const query = urlParams.get('query') || 'おまかせ';
            
            const res = await fetch(`/api/generate-recipe?query=${encodeURIComponent(query)}`);
            const d = await res.json();
            
            document.getElementById('r-name').innerText = d.name;
            document.getElementById('r-time').innerText = d.time;
            document.getElementById('r-cost').innerText = d.cost;
            document.getElementById('r-tip').innerText = d.tip;

            const ing = document.getElementById('ingredients');
            d.ingredients.forEach(i => {
                const div = document.createElement('div');
                div.className = 'ingredient-item';
                div.innerHTML = `<input type="checkbox" checked> <span>${i.name} (${i.amount})</span>`;
                ing.appendChild(div);
            });

            const stp = document.getElementById('steps');
            d.steps.forEach(s => { stp.innerHTML += `<p style="margin-bottom:8px;">・${s}</p>`; });

            document.getElementById('loading').style.display = 'none';
            document.getElementById('main-content').style.display = 'block';
        }

        async function download(elId, name) {
            const el = document.getElementById(elId);
            const canvas = await html2canvas(el, { backgroundColor: "#faf8f5", scale: 2 });
            const a = document.createElement('a');
            a.href = canvas.toDataURL("image/png");
            a.download = `${name}_${new Date().getTime()}.png`;
            a.click();
        }

        function saveCart() {
            const items = document.querySelectorAll('.ingredient-item');
            items.forEach(item => { if (!item.querySelector('input').checked) item.style.display = 'none'; });
            download('cart-area', '買い物リスト').then(() => {
                items.forEach(item => { item.style.display = 'flex'; });
            });
        }

        function saveRecipe() {
            download('recipe-area', 'カジラク特製レシピ');
        }

        init();
    </script>
</body>
</html>
